# ==========================================
# 高新医疗UDID查询系统 - 环境变量配置模板
# 部署日期: 2026-02-02
# ==========================================
# 使用说明:
# 1. 复制此文件为 .env: cp .env.template .env
# 2. 修改所有密钥值（必须！）
# 3. 设置文件权限: chmod 600 .env
# 4. 不要将此文件提交到版本控制
# ==========================================

# ==========================================
# AI 对话服务配置 (AI Chat Service)
# ==========================================
# API基础URL，支持OpenAI兼容格式
AI_API_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# AI模型名称
AI_MODEL=qwen-max

# API密钥（从数据库读取优先，此处为备用）
# AI_API_KEY=your_ai_api_key_here

# ==========================================
# 向量嵌入服务配置 (Embedding Service)
# ==========================================
# 嵌入API基础URL
EMBEDDING_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 嵌入模型名称
EMBEDDING_MODEL=text-embedding-v3

# 嵌入API密钥（从数据库读取优先，此处为备用）
# EMBEDDING_API_KEY=your_embedding_api_key_here

# ==========================================
# 同步服务 API 认证 (Sync Service Auth)
# ==========================================
# 同步服务API密钥，用于验证同步请求
# 生成命令: openssl rand -hex 16
SYNC_API_KEY=

# ==========================================
# Flask Session 密钥 (Session Security)
# ==========================================
# Flask会话密钥，用于加密会话数据
# 生成命令: openssl rand -hex 32
# 警告: 生产环境必须修改！
SECRET_KEY=

# 首次启动时默认管理员密码（仅在 users 表为空时使用）
# 要求: 至少12位，且包含大小写字母/数字/符号
ADMIN_DEFAULT_PASSWORD=

# ==========================================
# 数据库配置 (Database Backend)
# ==========================================
# 默认切换到 PostgreSQL。仅在回滚演练时改为 sqlite。
DB_BACKEND=postgres

# PostgreSQL 连接配置
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=udid_db
POSTGRES_USER=udid_user
# 生产环境必须设置强密码（长度>=16，混合字符）
POSTGRES_PASSWORD=
# PostgreSQL 连接池（每个 Gunicorn 进程独立维护）
POSTGRES_POOL_MIN=1
POSTGRES_POOL_MAX=12
# 连接池获取超时（秒）：高并发下若池满则等待可用连接，超时才失败
# POSTGRES_POOL_ACQUIRE_TIMEOUT=10

# SQLite 回滚路径（仅 DB_BACKEND=sqlite 时生效）
# SQLITE_DB_PATH=udid_hybrid_lake.db

# ==========================================
# 可选配置 (Optional Settings)
# ==========================================
# 服务端口（默认8080）
# PORT=8080

# Gunicorn worker 数（并发请求能力）
# GUNICORN_WORKERS=4

# Flask运行环境
# FLASK_ENV=production

# 日志级别 (DEBUG, INFO, WARNING, ERROR)
# LOG_LEVEL=INFO

# ==========================================
# 安全配置 (Security Settings)
# ==========================================
# 是否启用HTTPS（生产环境必须启用）
# SESSION_COOKIE_SECURE=true

# 管理员API密钥（可选，用于管理接口额外保护）
# ADMIN_API_KEY=your_admin_api_key_here
